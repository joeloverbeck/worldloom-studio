{
  "name": "@worldloom/web",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "dev": "vite --host 127.0.0.1",
    "test": "pnpm --filter @worldloom/shared build && vitest run",
    "typecheck": "pnpm --filter @worldloom/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "@worldloom/shared": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
