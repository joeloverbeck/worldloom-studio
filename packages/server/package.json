{
  "name": "@worldloom/server",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "pnpm --filter @worldloom/shared build && vitest run",
    "typecheck": "pnpm --filter @worldloom/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@worldloom/shared": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "hono": "^4.8.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.22.5",
    "vitest": "^4.1.9"
  }
}
